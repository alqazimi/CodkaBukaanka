# App database user (used by Prisma at runtime)
DATABASE_URL="postgresql://app_user:CHANGE_ME@localhost:5432/diiwaanka_bukaanka"

# One-time setup only — your local PostgreSQL superuser password
POSTGRES_PASSWORD="your-postgres-password"

PORT=4000
JWT_SECRET="REPLACE_WITH_32_PLUS_CHARACTER_RANDOM_SECRET"

# Local dev
FRONTEND_URL="http://localhost:3000"
FRONTEND_URLS="http://localhost:3000"

# Enforce admin 2FA at login (auto-enabled in production)
ENFORCE_ADMIN_TOTP=true

# Required in production for login captcha after failed attempts
# CAPTCHA_VERIFY_URL="https://challenges.cloudflare.com/turnstile/v0/siteverify"
# CAPTCHA_SECRET="your-turnstile-secret"

ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="ChangeMeToStrongPassword123!"

CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Public API base URL for locally stored uploads (Railway: https://your-service.up.railway.app)
# API_PUBLIC_URL="https://your-service.up.railway.app"

# Local dev: save uploads to backend/uploads/ when Cloudinary is missing or invalid
USE_LOCAL_UPLOADS=true

# Required when running multiple backend instances
# REDIS_URL="redis://localhost:6379"

# Set true when behind reverse proxy (nginx, Cloudflare, Railway)
# TRUST_PROXY=true

# Optional admin IP restriction (comma-separated)
# ADMIN_IP_ALLOWLIST="127.0.0.1"
