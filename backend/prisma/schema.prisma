generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WhatWentWrong {
  WRONG_MEDICATION
  WRONG_DOSAGE
  MISDIAGNOSIS
  DELAYED_TREATMENT
  NEGLIGENCE
  OTHER
}

enum CaseCategory {
  WRONG_MEDICATION
  MEDICATION_ERROR
  MISDIAGNOSIS
  DELAYED_TREATMENT
  MEDICAL_NEGLIGENCE
  SURGICAL_ERROR
  PATIENT_SAFETY_INCIDENT
  HOSPITAL_COMPLAINT
  OTHER
}

enum CaseStatus {
  DRAFT
  UNDER_REVIEW
  VERIFIED
  PUBLISHED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum EvidenceLevel {
  LOW
  MEDIUM
  HIGH
  VERIFIED
}

enum EvidenceType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum EvidenceVisibility {
  PUBLIC
  PRIVATE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  PUBLISH
  LOGIN
  LOGOUT
  LOGIN_FAILED
}

enum InboxStatus {
  NEW
  READ
  ARCHIVED
}

model Admin {
  id                  String           @id @default(cuid())
  email               String           @unique
  name                String
  passwordHash        String
  role                String           @default("admin")
  active              Boolean          @default(true)
  failedLoginAttempts Int              @default(0)
  lockedUntil         DateTime?
  totpSecret          String?
  totpEnabled         Boolean          @default(false)
  lastLoginAt         DateTime?
  lastLoginIp         String?
  lastLoginUserAgent  String?
  lastLoginRiskFlagged Boolean         @default(false)
  tokenVersion        Int              @default(0)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  auditLogs           AuditLog[]
  cases               Case[]           @relation("CaseAuthor")
  readInboxMessages   ContactMessage[] @relation("InboxReadBy")
  readCaseSubmissions CaseSubmission[] @relation("SubmissionReadBy")
}

model Hospital {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  location    String
  description String?   @db.Text
  deletedAt   DateTime?
  deletedById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  cases       Case[]
  doctors     Doctor[]

  @@index([slug])
  @@index([name])
  @@index([location])
  @@index([deletedAt])
}

model Patient {
  id          String    @id @default(uuid())
  fullName    String
  slug        String    @unique
  age         Int?
  gender      String?
  deletedAt   DateTime?
  deletedById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  cases       Case[]

  @@index([slug])
  @@index([fullName])
  @@index([deletedAt])
}

model Doctor {
  id          String    @id @default(uuid())
  fullName    String
  slug        String    @unique
  specialty   String?
  hospitalId  String?
  deletedAt   DateTime?
  deletedById String?
  hospital    Hospital? @relation(fields: [hospitalId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  cases       Case[]

  @@index([slug])
  @@index([fullName])
  @@index([hospitalId])
  @@index([deletedAt])
}

model Medication {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  type        String?
  deletedAt   DateTime?
  deletedById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  cases       Case[]

  @@index([name])
  @@index([slug])
  @@index([deletedAt])
}

model Case {
  id                  String        @id @default(uuid())
  caseNumber          String        @unique
  title               String
  slug                String        @unique
  reasonForVisit      String        @db.Text
  incidentDescription String        @db.Text
  currentCondition    String?       @db.Text
  whatWentWrong       WhatWentWrong
  category            CaseCategory
  status              CaseStatus    @default(DRAFT)
  riskLevel           RiskLevel
  evidenceLevel       EvidenceLevel @default(LOW)
  incidentDate        DateTime
  publishedAt         DateTime?
  patientId           String
  hospitalId          String
  doctorId            String?
  medicationId        String?
  authorId            String?
  patient             Patient       @relation(fields: [patientId], references: [id])
  hospital            Hospital      @relation(fields: [hospitalId], references: [id])
  doctor              Doctor?       @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  medication          Medication?   @relation(fields: [medicationId], references: [id], onDelete: SetNull)
  author              Admin?           @relation("CaseAuthor", fields: [authorId], references: [id])
  evidence            Evidence[]
  internalNotes       String?          @db.Text
  contactMessages     ContactMessage[]
  caseSubmissions     CaseSubmission[]
  deletedAt           DateTime?
  deletedById         String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([slug])
  @@index([caseNumber])
  @@index([hospitalId])
  @@index([deletedAt, updatedAt(sort: Desc)])
  @@index([patientId])
  @@index([doctorId])
  @@index([medicationId])
  @@index([category])
  @@index([whatWentWrong])
  @@index([status])
  @@index([riskLevel])
  @@index([evidenceLevel])
  @@index([incidentDate])
  @@index([title])
  @@index([status, riskLevel])
  @@index([status, category])
  @@index([status, hospitalId])
  @@index([deletedAt])
}

model Evidence {
  id          String             @id @default(uuid())
  caseId      String
  type        EvidenceType
  visibility  EvidenceVisibility @default(PUBLIC)
  url         String
  publicId    String?
  description String?            @db.Text
  fileName    String?
  mimeType    String?
  fileSize    Int?
  deletedAt   DateTime?
  deletedById String?
  case        Case               @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdAt   DateTime           @default(now())

  @@index([caseId])
  @@index([deletedAt])
  @@index([type])
  @@index([visibility])
  @@index([caseId, visibility, deletedAt])
}

model AuditLog {
  id         String      @id @default(cuid())
  adminId    String?
  admin      Admin?      @relation(fields: [adminId], references: [id], onDelete: SetNull)
  action     AuditAction
  entityType String
  entityId   String?
  details    String?     @db.Text
  ipAddress  String?
  createdAt  DateTime    @default(now())

  @@index([adminId])
  @@index([entityType])
  @@index([createdAt])
  @@index([adminId, createdAt(sort: Desc)])
}

model ContactMessage {
  id           String      @id @default(cuid())
  name         String
  email        String
  subject      String
  message      String      @db.Text
  status       InboxStatus @default(NEW)
  readAt       DateTime?
  readById     String?
  readBy       Admin?      @relation("InboxReadBy", fields: [readById], references: [id], onDelete: SetNull)
  internalNote String?     @db.Text
  linkedCaseId String?
  linkedCase   Case?       @relation(fields: [linkedCaseId], references: [id], onDelete: SetNull)
  deletedAt    DateTime?
  deletedById  String?
  createdAt    DateTime    @default(now())

  @@index([createdAt])
  @@index([deletedAt])
  @@index([subject])
  @@index([status])
  @@index([status, deletedAt])
}

model CaseSubmission {
  id                  String        @id @default(cuid())
  submitterName       String
  submitterEmail      String
  submitterPhone      String?
  submitterIp         String
  title               String
  reasonForVisit      String        @db.Text
  incidentDescription String        @db.Text
  currentCondition    String?       @db.Text
  whatWentWrong       WhatWentWrong
  category            CaseCategory
  incidentDate        DateTime
  hospitalName        String
  hospitalLocation    String?
  patientName         String
  patientAge          Int?
  patientGender       String?
  doctorName          String?
  medicationName      String?
  evidenceNotes       String        @db.Text
  status              InboxStatus   @default(NEW)
  readAt              DateTime?
  readById            String?
  readBy              Admin?        @relation("SubmissionReadBy", fields: [readById], references: [id], onDelete: SetNull)
  internalNote        String?       @db.Text
  linkedCaseId        String?
  linkedCase          Case?         @relation(fields: [linkedCaseId], references: [id], onDelete: SetNull)
  deletedAt           DateTime?
  deletedById         String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([createdAt])
  @@index([submitterIp, createdAt])
  @@index([status])
  @@index([deletedAt])
  @@index([status, deletedAt])
}
