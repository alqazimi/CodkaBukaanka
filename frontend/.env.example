# --- Production (Vercel) — replace with your real URLs ---
# Railway backend public URL (Settings → Networking → Public URL)
API_URL="https://YOUR-BACKEND.up.railway.app"
NEXT_PUBLIC_API_URL="https://YOUR-BACKEND.up.railway.app"

# Vercel frontend URL (no trailing slash, no /en)
AUTH_URL="https://codka-bukaanka-frontend.vercel.app"
NEXT_PUBLIC_SITE_URL="https://codka-bukaanka-frontend.vercel.app"

# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="minimum-32-character-random-secret"

NEXT_PUBLIC_SITE_NAME="CodkaBukaanka"
